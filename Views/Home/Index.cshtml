@{
    ViewData["Title"] = "BudgetBuddy - Personal Finance Management";
    Layout = "_layout";
}

    <div class="hero-section">
        <div class="hero-content">
            <!-- Logo -->
            <div class="logo">
                <i class="fas fa-chart-line"></i>
            </div>
            
            <!-- Main Title -->
            <h1 class="hero-title">Take Control of Your Finances</h1>
            
            <!-- Subtitle -->
            <p class="hero-subtitle">
                Track expenses, manage budgets, and achieve your financial goals with BudgetBuddy - 
                the simple and powerful personal finance manager.
            </p>
            
            <!-- Get Started Button -->
            <a href="@Url.Action("Login", "Account")" class="btn-get-started">
                Get Started with BudgetBuddy
            </a>
            
            <!-- Features Grid -->
            <div class="features">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <h3 class="feature-title">Expense Tracking</h3>
                    <p class="feature-description">
                        Easily track your daily expenses and see where your money is going with intuitive categorization.
                    </p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <h3 class="feature-title">Budget Management</h3>
                    <p class="feature-description">
                        Create and manage budgets for different categories and get alerts when you're close to your limits.
                    </p>
                </div>
                
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-bullseye"></i>
                    </div>
                    <h3 class="feature-title">Financial Goals</h3>
                    <p class="feature-description">
                        Set and track financial goals, whether it's saving for a vacation or paying off debt.
                    </p>
                </div>
            </div>
            
            <!-- Statistics -->
            <div class="stats">
                <div class="stat-item">
                    <div class="stat-number">10,000+</div>
                    <div class="stat-label">Happy Users</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">$50M+</div>
                    <div class="stat-label">Managed</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">24/7</div>
                    <div class="stat-label">Support</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">100%</div>
                    <div class="stat-label">Secure</div>
                </div>
            </div>
            
            <!-- Footer -->
            <div class="footer">
                <p>© 2025 BudgetBuddy. All rights reserved. Start your financial journey today.</p>
            </div>
        </div>
    </div>
