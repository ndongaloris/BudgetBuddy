@{
    ViewData["Title"] = "BudgetBuddy - Dashboard";
    Layout = "_layout";
}
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            @* background-color: rgba(181, 203, 222, 0.5); *@
            background-color: #F5F5F7
            @* background-color: #e3f2fd; *@
        }

        


    </style>
<body>

    <!-- NAV has been removed intentionally (coming from Layout/_Layout.cshtml). -->
    <!-- Main Content -->
    <div class="container-fluid px-4 py-3">
        <!-- Greeting Section -->
        <div class="greeting-section">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0 fw-bold" id="userGreeting">Hello, User!</h1>
                <div class="time-filters">
                    <button class="time-filter active">This month</button>
                    <button class="time-filter">Last month</button>
                    <button class="time-filter">This year</button>
                    <button class="time-filter">Last 12 months</button>
                </div>
            </div>
        </div>

        <!-- New layout: Pie chart on left, everything else on right -->
        <div class="row g-4">
            <!-- Left Column: Pie Chart -->
            <div class="col-lg-4">
                <div class="chart-container">
                    <div class="section-title">Expenses by category</div>
                    <div class="section-subtitle">Check your expenses by category</div>

                    <div style="position: relative; height: 280px; margin-bottom: 1.5rem;">
                        <canvas id="expensesChart"></canvas>
                    </div>

                    <!-- Category breakdown list within the same card -->
                    <div class="category-item">
                        <div class="d-flex align-items-center category-info">
                            <div class="category-color" style="background-color: #6366f1;"></div>
                            <span class="category-name ms-2">House</span>
                        </div>
                        <span class="category-percentage">41.35%</span>
                    </div>

                    <div class="category-item">
                        <div class="d-flex align-items-center category-info">
                            <div class="category-color" style="background-color: #ef4444;"></div>
                            <span class="category-name ms-2">Savings</span>
                        </div>
                        <span class="category-percentage">21.51%</span>
                    </div>

                    <div class="category-item">
                        <div class="d-flex align-items-center category-info">
                            <div class="category-color" style="background-color: #06b6d4;"></div>
                            <span class="category-name ms-2">Transportation</span>
                        </div>
                        <span class="category-percentage">15.47%</span>
                    </div>

                    <div class="category-item">
                        <div class="d-flex align-items-center category-info">
                            <div class="category-color" style="background-color: #10b981;"></div>
                            <span class="category-name ms-2">Groceries</span>
                        </div>
                        <span class="category-percentage">9.27%</span>
                    </div>

                    <div class="category-item">
                        <div class="d-flex align-items-center category-info">
                            <div class="category-color" style="background-color: #8b5cf6;"></div>
                            <span class="category-name ms-2">Shopping</span>
                        </div>
                        <span class="category-percentage">7.35%</span>
                    </div>

                    <div class="category-item">
                        <div class="d-flex align-items-center category-info">
                            <div class="category-color" style="background-color: #f59e0b;"></div>
                            <span class="category-name ms-2">Entertainment</span>
                        </div>
                        <span class="category-percentage">5.05%</span>
                    </div>
                </div>
            </div>

            <!-- Right Column: Metrics, Actions, and Transactions -->
            <div class="col-lg-8">
                <!-- Metrics Row -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="metric-card">
                            <div class="metric-title">Balance</div>
                            <div class="metric-value text-success">$5,502.45</div>
                            <div class="metric-change positive">+ 12.5%</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="metric-card">
                            <div class="metric-title">Incomes</div>
                            <div class="metric-value">$9,450.00</div>
                            <div class="metric-change positive">+ 27%</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="metric-card">
                            <div class="metric-title">Expenses</div>
                            <div class="metric-value">$3,945.55</div>
                            <div class="metric-change negative">- 15%</div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons Row -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <a href="add-income.html" class="action-button">
                            <div class="action-icon income">
                                <i class="fas fa-plus"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Add Income</div>
                                <div class="text-muted small">Create an income manually</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="add-expense.html" class="action-button">
                            <div class="action-icon expense">
                                <i class="fas fa-plus"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Add expense</div>
                                <div class="text-muted small">Create an expense manually</div>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Transactions List -->
                <div class="transactions-container">
                    <div class="section-title">Last transactions</div>
                    <div class="section-subtitle">Check your last transactions</div>

                    <div class="table-responsive">
                        <table class="table table-borderless">
                            <thead>
                                <tr class="text-muted small">
                                    <th>Description</th>
                                    <th>Category</th>
                                    <th>Date</th>
                                    <th class="text-end">Amount</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="transaction-icon" style="background-color: #fff3cd; color: #856404;">OR</div>
                                            <span class="fw-medium">Orlando Rodriguez</span>
                                        </div>
                                    </td>
                                    <td><span class="text-muted">Bank account</span></td>
                                    <td><span class="text-muted">2024/04/01</span></td>
                                    <td class="text-end"><span class="text-success fw-semibold">+$750.00</span></td>
                                    <td><i class="fas fa-ellipsis-v text-muted"></i></td>
                                </tr>

                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="transaction-icon" style="background-color: #d1ecf1; color:#0c5460;">N</div>
                                            <span class="fw-medium">Netflix</span>
                                        </div>
                                    </td>
                                    <td><span class="text-muted">Credit card</span></td>
                                    <td><span class="text-muted">2024/03/29</span></td>
                                    <td class="text-end"><span class="fw-semibold">$9.90</span></td>
                                    <td><i class="fas fa-ellipsis-v text-muted"></i></td>
                                </tr>

                                <!-- other rows... -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        
    </script>
</body>
</html>
