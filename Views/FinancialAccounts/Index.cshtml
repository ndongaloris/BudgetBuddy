@* File: Views/FinancialAccounts/Index.cshtml *@

@model IEnumerable<Financy.Models.Account>

@{
    ViewData["Title"] = "My Accounts - Financy";
    Layout = "_Layout";

    // Ensure ViewBag.TotalBalance is a decimal (controller sets it)
    var totalBalance = (ViewBag.TotalBalance as decimal?) ?? 0m;
    var totalNegative = totalBalance < 0m;
    string totalClass = totalNegative ? "text-balance-negative" : "text-success";
}

@functions {
    // pick icon color based on account type
    string GetAccountIconColor(string type)
    {
        return type?.ToLower() switch
        {
            "checking" => "#1976d2",   // blue
            "savings" => "#28a745",    // green
            "credit" or "credit card" => "#f57c00", // orange
            _ => "#6c757d"             // gray default
        };
    }

    // pick font-awesome icon based on account type
    string GetAccountIcon(string type)
    {
        return type?.ToLower() switch
        {
            "checking" => "fas fa-university",
            "savings" => "fas fa-piggy-bank",
            "credit" or "credit card" => "fas fa-credit-card",
            _ => "fas fa-wallet"
        };
    }
}

<style>
    body {
        background-color: #f8f9fa !important;
    }

    .container-fluid {
        background-color: transparent !important;
    }

    .my-account { color: #000; }
    .manage-finance { padding-bottom: 10px; }

    /* negative color (dark orange) */
    .text-balance-negative { color: #cc7000 !important; }

    /* account balance classes */
    .account-balance.positive { color: #28a745; font-weight: 700; font-size: 1.25rem; }
    .account-balance.negative { color: #cc7000; font-weight: 700; font-size: 1.25rem; }

    .account-balance-large.positive { color: #28a745; }
    .account-balance-large.negative { color: #cc7000; }
</style>

<div class="container-fluid px-4 py-4">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0 fw-bold my-account">My Accounts</h1>
                <p class="text-muted mb-0 manage-finance">Manage your financial accounts and track balances</p>
            </div><br>
            <button id="openAddAccountBtn" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addAccountModal">
                <i class="fas fa-plus me-2"></i>Add Account
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }


    <div class="summary-section mb-4">
    <h5 class="mb-3">Account Summary</h5>
    <div class="summary-grid d-flex gap-3 justify-content-between">
        <div class="summary-item p-3 bg-white rounded shadow-sm flex-fill" style="min-width:180px; max-width: calc(25% - 12px);">
            <div class="d-flex align-items-center gap-2">
                <div class="summary-icon p-2 rounded" style="background-color: #e8f5e8; color: #28a745;">
                    <i class="fas fa-wallet"></i>
                </div>
                <div>
                    <div class="summary-title small text-muted">Total Balance</div>
                    <div class="summary-value fw-bold @totalClass">
                        @(
                            totalNegative
                            ? "-" + Math.Abs(totalBalance).ToString("C")
                            : totalBalance.ToString("C")
                        )
                    </div>
                </div>
            </div>
        </div>

        <div class="summary-item p-3 bg-white rounded shadow-sm flex-fill" style="min-width:160px; max-width: calc(25% - 12px);">
            <div class="d-flex align-items-center gap-2">
                <div class="summary-icon p-2 rounded" style="background-color: #e3f2fd; color: #1976d2;">
                    <i class="fas fa-university"></i>
                </div>
                <div>
                    <div class="summary-title small text-muted">Total Accounts</div>
                    <div class="summary-value fw-bold">@ViewBag.TotalAccounts</div>
                </div>
            </div>
        </div>

        <div class="summary-item p-3 bg-white rounded shadow-sm flex-fill" style="min-width:160px; max-width: calc(25% - 12px);">
            <div class="d-flex align-items-center gap-2">
                <div class="summary-icon p-2 rounded" style="background-color: #fff3e0; color: #f57c00;">
                    <i class="fas fa-credit-card"></i>
                </div>
                <div>
                    <div class="summary-title small text-muted">Credit Cards</div>
                    <div class="summary-value fw-bold">@ViewBag.CreditCards</div>
                </div>
            </div>
        </div>

        <div class="summary-item p-3 bg-white rounded shadow-sm flex-fill" style="min-width:160px; max-width: calc(25% - 12px);">
            <div class="d-flex align-items-center gap-2">
                <div class="summary-icon p-2 rounded" style="background-color: #f3e5f5; color: #7b1fa2;">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div>
                    <div class="summary-title small text-muted">Checking Accounts</div>
                    <div class="summary-value fw-bold">@ViewBag.CheckingAccounts</div>
                </div>
            </div>
        </div>
    </div>
</div>

