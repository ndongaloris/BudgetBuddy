    <div class="row">
        @foreach (var account in Model)
        {
            var isNegative = account.Balance < 0m;
            <div class="col-lg-6 mb-4">
                <div class="account-card p-3 bg-white rounded shadow-sm h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="d-flex align-items-center">
                            <div class="account-icon me-3" style="width:48px;height:48px;border-radius:50%;background:@GetAccountIconColor(account.Type);color:white;display:flex;align-items:center;justify-content:center;">
                                <i class="@GetAccountIcon(account.Type)"></i>
                            </div>
                            <div>
                                <div class="account-name fw-semibold">@account.Name</div>
                                <div class="text-muted small">@account.Type</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <a asp-action="Details" asp-route-id="@account.Id" class="btn btn-sm btn-light" title="View Details">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="#" class="btn btn-sm btn-light text-warning edit-account" data-id="@account.Id" data-name="@account.Name" data-type="@account.Type" data-balance="@account.Balance" title="Edit Account">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="#" class="btn btn-sm btn-light text-danger delete-account" data-id="@account.Id" data-name="@account.Name" title="Delete Account">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="account-balance @(isNegative ? "negative" : "positive")">
                            @(
                                isNegative
                                ? "-" + Math.Abs(account.Balance).ToString("C")
                                : account.Balance.ToString("C")
                            )
                        </div>

                        <div class="account-details mt-3 d-flex gap-3">
                            <div class="detail-item p-2 bg-light rounded" style="min-width:120px;">
                                <div class="detail-label small text-muted">Available</div>
                                <div class="detail-value">
                                    @(
                                        isNegative
                                        ? "-" + Math.Abs(account.Balance).ToString("C")
                                        : account.Balance.ToString("C")
                                    )
                                </div>
                            </div>

                            <div class="detail-item p-2 bg-light rounded" style="min-width:120px;">
                                <div class="detail-label small text-muted">Type</div>
                                <div class="detail-value">@account.Type</div>
                            </div>

                            <div class="detail-item p-2 bg-light rounded" style="min-width:120px;">
                                <div class="detail-label small text-muted">Last Updated</div>
                                <div class="detail-value">Just now</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">No accounts found. Add an account to get started.</div>
            </div>
        }
    </div>
</div>

<!-- ============================= -->
<!-- ADD / EDIT / DELETE MODALS -->
<!-- ============================= -->

<!-- Add Account Modal -->
<div class="modal fade" id="addAccountModal" tabindex="-1" aria-labelledby="addAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="FinancialAccounts" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="addAccountModalLabel">Add Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="addAccountName" class="form-label">Account Name</label>
                        <input id="addAccountName" name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="addAccountType" class="form-label">Account Type</label>
                        <select id="addAccountType" name="Type" class="form-select">
                            <option value="">Select type</option>
                            <option>Checking</option>
                            <option>Savings</option>
                            <option>Credit Card</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="addAccountBalance" class="form-label">Initial Balance</label>
                        <input id="addAccountBalance" name="Balance" type="number" step="0.01" class="form-control" value="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success btn-lg">Add Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Account Modal -->
<div class="modal fade" id="editAccountModal" tabindex="-1" aria-labelledby="editAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="FinancialAccounts" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editAccountId" name="Id" value="" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editAccountModalLabel">Edit Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editAccountName" class="form-label">Account Name</label>
                        <input id="editAccountName" name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="editAccountType" class="form-label">Account Type</label>
                        <select id="editAccountType" name="Type" class="form-select">
                            <option value="">Select type</option>
                            <option>Checking</option>
                            <option>Savings</option>
                            <option>Credit Card</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="editAccountBalance" class="form-label">Balance</label>
                        <input id="editAccountBalance" name="Balance" type="number" step="0.01" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Account Modal -->
<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="FinancialAccounts" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteAccountId" name="id" value="" />
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteAccountModalLabel">Delete Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete the account "<strong id="deleteAccountName"></strong>"? This action cannot be undone.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <!-- Note: your controller has [HttpPost, ActionName("Delete")] DeleteConfirmed(int id) -->
                    <button type="submit" class="btn btn-danger btn-lg">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Keep your modal JS wiring
        document.addEventListener("DOMContentLoaded", () => {
            // Edit buttons
            document.querySelectorAll(".edit-account").forEach(btn => {
                btn.addEventListener("click", e => {
                    e.preventDefault();
                    const id = btn.dataset.id;
                    const name = btn.dataset.name;
                    const type = btn.dataset.type;
                    const balance = btn.dataset.balance;

                    // fill modal fields
                    const idEl = document.getElementById("editAccountId");
                    const nameEl = document.getElementById("editAccountName");
                    const typeEl = document.getElementById("editAccountType");
                    const balanceEl = document.getElementById("editAccountBalance");

                    if (idEl) idEl.value = id ?? "";
                    if (nameEl) nameEl.value = name ?? "";
                    if (typeEl) typeEl.value = type ?? "";
                    if (balanceEl) balanceEl.value = balance ?? "0";

                    // open modal
                    const modalEl = document.getElementById("editAccountModal");
                    if (modalEl) new bootstrap.Modal(modalEl).show();
                });
            });

            // Delete buttons
            document.querySelectorAll(".delete-account").forEach(btn => {
                btn.addEventListener("click", e => {
                    e.preventDefault();
                    const id = btn.dataset.id;
                    const name = btn.dataset.name;

                    const idEl = document.getElementById("deleteAccountId");
                    const nameEl = document.getElementById("deleteAccountName");

                    if (idEl) idEl.value = id ?? "";
                    if (nameEl) nameEl.textContent = name ?? "";

                    const modalEl = document.getElementById("deleteAccountModal");
                    if (modalEl) new bootstrap.Modal(modalEl).show();
                });
            });

            // Optional: focus first input when opening Add Account modal
            const addAccountModalEl = document.getElementById("addAccountModal");
            if (addAccountModalEl) {
                addAccountModalEl.addEventListener('shown.bs.modal', function () {
                    const el = document.getElementById("addAccountName");
                    if (el) el.focus();
                });
            }
        });
    </script>
}
