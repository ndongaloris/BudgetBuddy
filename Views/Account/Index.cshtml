@model IEnumerable<Financy.Models.Account>

@{
    ViewData["Title"] = "BudgetBuddy - Personal Finance Management";
    Layout = "_Layout";
}

    <!-- Main Content -->
    <div class="container-fluid px-4 py-4">
        <!-- Page Header -->
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 fw-bold">My Accounts</h1>
                    <p class="text-muted mb-0">Manage your financial accounts and track balances</p>
                </div>
                <button class="btn btn-add-account" data-bs-toggle="modal" data-bs-target="#addAccountModal">
                    <i class="fas fa-plus me-2"></i>Add Account
                </button>
            </div>
        </div>

        <!-- Summary Section -->
        <div class="summary-section">
            <h5 class="mb-4">Account Summary</h5>
            <div class="summary-grid">
                <div class="summary-item">
                    <div class="summary-icon" style="background-color: #e8f5e8; color: #28a745;">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <div class="summary-title">Total Balance</div>
                    <div class="summary-value" style="color: #28a745;">$12,847.32</div>
                </div>
                <div class="summary-item">
                    <div class="summary-icon" style="background-color: #e3f2fd; color: #1976d2;">
                        <i class="fas fa-university"></i>
                    </div>
                    <div class="summary-title">Bank Accounts</div>
                    <div class="summary-value">3</div>
                </div>
                <div class="summary-item">
                    <div class="summary-icon" style="background-color: #fff3e0; color: #f57c00;">
                        <i class="fas fa-credit-card"></i>
                    </div>
                    <div class="summary-title">Credit Cards</div>
                    <div class="summary-value">2</div>
                </div>
                <div class="summary-item">
                    <div class="summary-icon" style="background-color: #f3e5f5; color: #7b1fa2;">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="summary-title">Investments</div>
                    <div class="summary-value">1</div>
                </div>
            </div>
        </div>

        <!-- Accounts List -->
        <div class="row">
            <!-- Checking Account -->
            <div class="col-lg-6">
                <div class="account-card">
                    <div class="account-header">
                        <div class="d-flex align-items-center">
                            <div class="account-icon" style="background-color: #e3f2fd; color: #1976d2;">
                                <i class="fas fa-university"></i>
                            </div>
                            <div class="account-info">
                                <div class="account-name">Chase Checking</div>
                                <div class="account-type">Checking Account • ****4521</div>
                            </div>
                        </div>
                        <div class="account-actions">
                            <button class="btn-action" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-action" title="More">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                        </div>
                    </div>
                    <div class="account-balance positive">$5,247.89</div>
                    <div class="account-details">
                        <div class="detail-item">
                            <div class="detail-label">Available</div>
                            <div class="detail-value">$5,247.89</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Pending</div>
                            <div class="detail-value">$0.00</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Last Updated</div>
                            <div class="detail-value">Today</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Savings Account -->
            <div class="col-lg-6">
                <div class="account-card">
                    <div class="account-header">
                        <div class="d-flex align-items-center">
                            <div class="account-icon" style="background-color: #e8f5e8; color: #28a745;">
                                <i class="fas fa-piggy-bank"></i>
                            </div>
                            <div class="account-info">
                                <div class="account-name">High Yield Savings</div>
                                <div class="account-type">Savings Account • ****7832</div>
                            </div>
                        </div>
                        <div class="account-actions">
                            <button class="btn-action" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-action" title="More">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                        </div>
                    </div>
                    <div class="account-balance positive">$8,450.00</div>
                    <div class="account-details">
                        <div class="detail-item">
                            <div class="detail-label">Available</div>
                            <div class="detail-value">$8,450.00</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">APY</div>
                            <div class="detail-value">4.5%</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Interest Earned</div>
                            <div class="detail-value">$32.15</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Credit Card -->
            <div class="col-lg-6">
                <div class="account-card">
                    <div class="account-header">
                        <div class="d-flex align-items-center">
                            <div class="account-icon" style="background-color: #fff3e0; color: #f57c00;">
                                <i class="fas fa-credit-card"></i>
                            </div>
                            <div class="account-info">
                                <div class="account-name">Chase Freedom</div>
                                <div class="account-type">Credit Card • ****9876</div>
                            </div>
                        </div>
                        <div class="account-actions">
                            <button class="btn-action" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-action" title="More">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                        </div>
                    </div>
                    <div class="account-balance negative">-$1,247.32</div>
                    <div class="account-details">
                        <div class="detail-item">
                            <div class="detail-label">Balance</div>
                            <div class="detail-value">$1,247.32</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Credit Limit</div>
                            <div class="detail-value">$5,000.00</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Available</div>
                            <div class="detail-value">$3,752.68</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Investment Account -->
            <div class="col-lg-6">
                <div class="account-card">
                    <div class="account-header">
                        <div class="d-flex align-items-center">
                            <div class="account-icon" style="background-color: #f3e5f5; color: #7b1fa2;">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div class="account-info">
                                <div class="account-name">Investment Portfolio</div>
                                <div class="account-type">Brokerage Account • ****1234</div>
                            </div>
                        </div>
                        <div class="account-actions">
                            <button class="btn-action" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-action" title="More">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                        </div>
                    </div>
                    <div class="account-balance positive">$15,892.45</div>
                    <div class="account-details">
                        <div class="detail-item">
                            <div class="detail-label">Total Value</div>
                            <div class="detail-value">$15,892.45</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Day Change</div>
                            <div class="detail-value" style="color: #28a745;">+$127.32</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Total Return</div>
                            <div class="detail-value" style="color: #28a745;">+12.4%</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PayPal Account -->
            <div class="col-lg-6">
                <div class="account-card">
                    <div class="account-header">
                        <div class="d-flex align-items-center">
                            <div class="account-icon" style="background-color: #e3f2fd; color: #1976d2;">
                                <i class="fab fa-paypal"></i>
                            </div>
                            <div class="account-info">
                                <div class="account-name">PayPal</div>
                                <div class="account-type">Digital Wallet • mark@email.com</div>
                            </div>
                        </div>
                        <div class="account-actions">
                            <button class="btn-action" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-action" title="More">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                        </div>
                    </div>
                    <div class="account-balance positive">$342.18</div>
                    <div class="account-details">
                        <div class="detail-item">
                            <div class="detail-label">Available</div>
                            <div class="detail-value">$342.18</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Pending</div>
                            <div class="detail-value">$0.00</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Status</div>
                            <div class="detail-value">Verified</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cash Account -->
            <div class="col-lg-6">
                <div class="account-card">
                    <div class="account-header">
                        <div class="d-flex align-items-center">
                            <div class="account-icon" style="background-color: #e8f5e8; color: #28a745;">
                                <i class="fas fa-money-bill-wave"></i>
                            </div>
                            <div class="account-info">
                                <div class="account-name">Cash</div>
                                <div class="account-type">Physical Cash</div>
                            </div>
                        </div>
                        <div class="account-actions">
                            <button class="btn-action" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-action" title="More">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                        </div>
                    </div>
                    <div class="account-balance positive">$125.00</div>
                    <div class="account-details">
                        <div class="detail-item">
                            <div class="detail-label">On Hand</div>
                            <div class="detail-value">$125.00</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Last Updated</div>
                            <div class="detail-value">Yesterday</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Currency</div>
                            <div class="detail-value">USD</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Account Modal -->
    <div class="modal fade" id="addAccountModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addAccountForm">
                        <div class="mb-3">
                            <label class="form-label">Account Name</label>
                            <input type="text" class="form-control" placeholder="e.g., Chase Checking" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Account Type</label>
                            <select class="form-select" required>
                                <option value="">Select account type</option>
                                <option value="checking">Checking Account</option>
                                <option value="savings">Savings Account</option>
                                <option value="credit">Credit Card</option>
                                <option value="investment">Investment Account</option>
                                <option value="cash">Cash</option>
                                <option value="paypal">PayPal</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Initial Balance</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" placeholder="0.00" step="0.01">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Account Number (Optional)</label>
                            <input type="text" class="form-control" placeholder="Last 4 digits">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary">Add Account</button>
                </div>
            </div>
        </div>
    </div>
