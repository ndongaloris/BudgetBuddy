
@*  Views/Account/ExternalLoginConfirmation.cshtml *@

@model Financy.Models.ViewModels.ExternalLoginConfirmationViewModel

@{
    ViewData["Title"] = "Complete Registration";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Registration - Financy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome@6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }
        
        .registration-container {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
        }
        
        .form-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 1.5rem;
            text-align: center;
        }
        
        .form-label {
            font-weight: 500;
            color: #495057;
            margin-bottom: 0.5rem;
        }
        
        .form-control {
            background-color: #e9ecef;
            border: none;
            border-radius: 8px;
            padding: 0.875rem 1rem;
            font-size: 0.95rem;
            margin-bottom: 1.25rem;
        }
        
        .btn-complete {
            background-color: #ffd54f;
            border: none;
            border-radius: 8px;
            padding: 0.875rem 2rem;
            font-weight: 600;
            color: #333;
            width: 100%;
            transition: all 0.3s ease;
        }
        
        .btn-complete:hover {
            background-color: #ffcc02;
            color: #333;
            transform: translateY(-1px);
        }
        
        .profile-preview {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        
        .profile-image {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 1rem;
        }
        
        .profile-initials {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background-color: #6c757d;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            font-weight: 600;
            margin: 0 auto 1rem auto;
        }
        
        .text-danger {
            color: #dc3545;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="registration-container">
        <h2 class="form-title">Complete Your Registration</h2>
        
        <div class="profile-preview">
            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" alt="Profile" class="profile-image">
            }
            else
            {
                <div class="profile-initials">
                    @GetInitials(Model.FullName)
                </div>
            }
            <p>Signed in with external provider</p>
        </div>
        
        <form asp-action="ExternalLoginConfirmation" method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="ProfileImageUrl" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label class="form-label" asp-for="FullName">Full Name</label>
                <input type="text" class="form-control" asp-for="FullName" required>
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label class="form-label" asp-for="Email">Email</label>
                <input type="email" class="form-control" asp-for="Email" disabled>
                <small class="text-muted">Email cannot be changed</small>
            </div>
            
            <button type="submit" class="btn btn-complete">Complete Registration</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @functions {
        private string GetInitials(string fullName)
        {
            if (string.IsNullOrWhiteSpace(fullName))
                return "U";
                
            var names = fullName.Split(' ');
            if (names.Length == 1)
                return names[0][0].ToString().ToUpper();
                
            return (names[0][0].ToString() + names[^1][0].ToString()).ToUpper();
        }
    }
</body>
</html>