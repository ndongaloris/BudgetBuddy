<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0 fw-bold" style="color:black">All Transactions</h1>
                <p class="text-muted mb-0">View and manage all your financial transactions</p>
                <br>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Transactions" asp-action="AddIncome" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>Add Income
                </a>
                <a asp-controller="Transactions" asp-action="AddExpense" class="btn btn-danger">
                    <i class="fas fa-plus me-2"></i>Add Expense
                </a>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <!-- <div class="summary-cards">
        <div class="summary-card">
            <div class="summary-title">Total Income</div>
            <div class="summary-value income">@totalIncome.ToString("C")</div>
        </div>
        <div class="summary-card">
            <div class="summary-title">Total Expenses</div>
            <div class="summary-value expense">@totalExpenses.ToString("C")</div>
        </div>
        <div class="summary-card">
            <div class="summary-title">Net Balance</div>
            <div class="summary-value @balanceClass">
                @(netBalance < 0 ? "-" + Math.Abs(netBalance).ToString("C") : netBalance.ToString("C"))
            </div>
        </div>
        <div class="summary-card">
            <div class="summary-title">Transactions</div>
            <div class="summary-value">@transactionsCount</div>
        </div>
    </div> -->

    <!-- Summary Cards -->
<div class="summary-cards">
    <div class="summary-card">
        <div class="summary-title">Total Income</div>
        <div class="summary-value income">@totalIncome.ToString("C")</div>
    </div>
    <div class="summary-card">
        <div class="summary-title">Total Expenses</div>
        <div class="summary-value expense">@totalExpenses.ToString("C")</div>
    </div>
    <div class="summary-card">
        <div class="summary-title">Net Balance</div>
        <div class="summary-value @balanceClass">
            @(netBalance < 0 ? "-" + Math.Abs(netBalance).ToString("C") : netBalance.ToString("C"))
        </div>
    </div>
    <div class="summary-card">
        <div class="summary-title">Transactions</div>
        <div class="summary-value">@transactionsCount</div>
    </div>
</div>


    <!-- Filters -->
    <div class="filters-container mb-3">
        <h5 class="mb-3">Filter Transactions</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="filter-label">Date Range</label>
                <select class="form-select" id="dateRange">
                    <option value="all" selected="@(dateRange=="all" ? "selected" : null)">All Time</option>
                    <option value="today" selected="@(dateRange=="today" ? "selected" : null)">Today</option>
                    <option value="week" selected="@(dateRange=="week" ? "selected" : null)">This Week</option>
                    <option value="month" selected="@(dateRange=="month" ? "selected" : null)">This Month</option>
                    <option value="quarter" selected="@(dateRange=="quarter" ? "selected" : null)">This Quarter</option>
                    <option value="year" selected="@(dateRange=="year" ? "selected" : null)">This Year</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="filter-label">Type</label>
                <select class="form-select" id="transactionType">
                    <option value="all" selected="@(typeFilter=="all" ? "selected" : null)">All Types</option>
                    <option value="income" selected="@(typeFilter=="income" ? "selected" : null)">Income Only</option>
                    <option value="expense" selected="@(typeFilter=="expense" ? "selected" : null)">Expenses Only</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="filter-label">Category</label>
                <select class="form-select" id="category">
                    <option value="0" selected="@(categoryId==0 ? "selected" : null)">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id" selected="@(categoryId == cat.Id ? "selected" : null)">@cat.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="filter-label">Search</label>
                <input type="text" class="form-control" id="searchTerm" placeholder="Search transactions..." value="@searchTerm" style="padding:7px; margin-top:18px;">
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-filter btn-primary btn-sm" onclick="applyFilters()">
                <i class="fas fa-filter me-2"></i>Apply Filters
            </button>
            <button class="btn btn-clear btn-outline-secondary btn-sm" onclick="clearFilters()">
                <i class="fas fa-times me-2"></i>Clear All
            </button>

            <a id="exportBtn" class="btn-outline-secondary ms-auto" href="@Url.Action("Export", "Transactions", new { dateRange, type = typeFilter, categoryId, search = searchTerm, sort })">
                <!-- <i class="fas fa-download me-1"></i>Export CSV -->
            </a>

            <!-- <select id="sortSelect" class="form-select form-select-sm" style="width:auto; margin-left:8px" onchange="changeSort()">
                <option value="date_desc" selected="@(sort=="date_desc" ? "selected" : null)">Sort by Date (newest)</option>
                <option value="date_asc" selected="@(sort=="date_asc" ? "selected" : null)">Sort by Date (oldest)</option>
                <option value="amount_desc" selected="@(sort=="amount_desc" ? "selected" : null)">Sort by Amount (high→low)</option>
                <option value="amount_asc" selected="@(sort=="amount_asc" ? "selected" : null)">Sort by Amount (low→high)</option>
                <option value="category_asc" selected="@(sort=="category_asc" ? "selected" : null)">Sort by Category (A→Z)</option>
                <option value="category_desc" selected="@(sort=="category_desc" ? "selected" : null)">Sort by Category (Z→A)</option>
            </select> -->
        </div>
    </div>

    <!-- Transactions List -->
    <!-- <div class="transactions-container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Recent Transactions</h5>
            <a id="exportBtnTop" class="btn btn-sm btn-outline-secondary" href="@Url.Action("Export", "Transactions", new { dateRange, type = typeFilter, categoryId, search = searchTerm, sort })">
                <i class="fas fa-download me-1"></i>Export CSV
            </a>
        </div> -->

        <!-- Transactions List -->
<div class="transactions-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Recent Transactions</h5>
        <div class="d-flex gap-2 align-items-center">
            <a id="exportBtnTop" class="btn btn-sm btn-outline-secondary" href="@Url.Action("Export", "Transactions", new { dateRange, type = typeFilter, categoryId, search = searchTerm, sort })">
                <i class="fas fa-download me-1"></i>Export CSV
            </a>
            <select id="sortSelect" class="form-select form-select-sm" style="width:auto;" onchange="changeSort()">
                <option value="date_desc" selected="@(sort=="date_desc" ? "selected" : null)">Sort by Date (newest)</option>
                <option value="date_asc" selected="@(sort=="date_asc" ? "selected" : null)">Sort by Date (oldest)</option>
                <option value="amount_desc" selected="@(sort=="amount_desc" ? "selected" : null)">Sort by Amount (high→low)</option>
                <option value="amount_asc" selected="@(sort=="amount_asc" ? "selected" : null)">Sort by Amount (low→high)</option>
                <option value="category_asc" selected="@(sort=="category_asc" ? "selected" : null)">Sort by Category (A→Z)</option>
                <option value="category_desc" selected="@(sort=="category_desc" ? "selected" : null)">Sort by Category (Z→A)</option>
            </select>
        </div>
    </div>


        <div id="transactionsList">
            @if (!Model.Any())
            {
                <div class="text-muted">No transactions found.</div>
            }
            else
            {
                foreach (var tx in Model)
                {
                    <div class="transaction-item">
                        <div class="transaction-icon" style="background-color:@(tx.IsIncome ? "#d4edda" : "#f8d7da"); color:@(tx.IsIncome ? "#155724" : "#721c24");">
                            @GetInitials(tx.Description)
                        </div>
                        <div class="transaction-details">
                            <div class="transaction-name">@tx.Description</div>
                            <div class="transaction-meta">
                                <span><i class="fas fa-tag me-1"></i>@(tx.Category?.Name ?? "Uncategorized")</span>
                                <span><i class="fas fa-credit-card me-1"></i>@(tx.Account?.Name ?? "N/A")</span>
                                <span><i class="fas fa-calendar me-1"></i>@tx.Date.ToShortDateString()</span>
                            </div>
                        </div>
                        <div class="transaction-amount @(tx.IsIncome ? "positive" : "negative")">
                            @(tx.IsIncome ? "+" : "-")@tx.Amount.ToString("C")
                        </div>
                        <div class="transaction-actions">
                            <a asp-controller="Transactions" asp-action="@(tx.IsIncome ? "EditIncome" : "EditExpense")" asp-route-id="@tx.Id" class="btn-action" title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-controller="Transactions" asp-action="@(tx.IsIncome ? "DeleteIncomeConfirmed" : "DeleteExpenseConfirmed")" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@tx.Id" />
                                <button type="submit" class="btn-action text-danger" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Pagination -->
        <div class="pagination-container">
            <div class="results-info">
                Showing page @currentPage of @totalPages — @transactionsCount result(s)
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="javascript:goToPage(@(currentPage - 1))">Previous</a>
                    </li>
                    @for (int p = Math.Max(1, currentPage - 3); p <= Math.Min(totalPages, currentPage + 3); p++)
                    {
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a class="page-link" href="javascript:goToPage(@p)">@p</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="javascript:goToPage(@(currentPage + 1))">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function buildQueryString(overrides = {}) {
            const dateRange = overrides.dateRange ?? document.getElementById('dateRange').value;
            const type = overrides.type ?? document.getElementById('transactionType').value;
            const categoryId = overrides.categoryId ?? document.getElementById('category').value;
            const search = overrides.search ?? document.getElementById('searchTerm').value;
            const sort = overrides.sort ?? document.getElementById('sortSelect').value;

            // ✅ FIX: currentPage instead of page
            const pageNum = overrides.page ?? @Html.Raw(currentPage);
            const pageSize = overrides.pageSize ?? @Html.Raw(pageSize);

            const params = new URLSearchParams();
            if (dateRange) params.append('dateRange', dateRange);
            if (type) params.append('type', type);
            if (categoryId) params.append('categoryId', categoryId);
            if (search) params.append('search', search);
            if (sort) params.append('sort', sort);
            if (pageNum) params.append('page', pageNum);
            if (pageSize) params.append('pageSize', pageSize);
            return params.toString();
        }

        function applyFilters() {
            const qs = buildQueryString({ page: 1 });
            window.location = '@Url.Action("Index","Transactions")' + '?' + qs;
        }

        function clearFilters() {
            document.getElementById('dateRange').value = 'month';
            document.getElementById('transactionType').value = 'all';
            document.getElementById('category').value = '0';
            document.getElementById('searchTerm').value = '';
            document.getElementById('sortSelect').value = 'date_desc';
            applyFilters();
        }

        function changeSort() {
            const qs = buildQueryString({ page: 1 });
            window.location = '@Url.Action("Index","Transactions")' + '?' + qs;
        }

        function goToPage(p) {
            const qs = buildQueryString({ page: p });
            window.location = '@Url.Action("Index","Transactions")' + '?' + qs;
        }

        (function updateExportLinks() {
            const qs = buildQueryString();
            var url = '@Url.Action("Export", "Transactions")' + '?' + qs;
            document.getElementById('exportBtn').href = url;
            document.getElementById('exportBtnTop').href = url;
        })();
    </script>
}

@functions {
    private string GetInitials(string description)
    {
        if (string.IsNullOrWhiteSpace(description)) return "";
        var words = description.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length == 1) return words[0].Substring(0, 1).ToUpper();
        return (words[0][0].ToString() + words[1][0].ToString()).ToUpper();
    }
}
