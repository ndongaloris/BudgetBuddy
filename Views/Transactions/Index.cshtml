@model IEnumerable<Financy.Models.Transaction>

@{
    ViewData["Title"] = "BudgetBuddy - Personal Finance Management";
    Layout = "_Layout";
}


<!-- Main Content -->
    <div class="container-fluid px-4 py-4">
        <!-- Page Header -->
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 fw-bold">All Transactions</h1>
                    <p class="text-muted mb-0">View and manage all your financial transactions</p>
                </div>
                <div class="d-flex gap-2">
                    <a href="../Transactions/addIncome" class="btn btn-success">
                        <i class="fas fa-plus me-2"></i>Add Income
                    </a>
                    <a href="../Transactions/addExpense" class="btn btn-danger">
                        <i class="fas fa-plus me-2"></i>Add Expense
                    </a>
                </div>
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="summary-card">
                <div class="summary-title">Total Income</div>
                <div class="summary-value income">$9,450.00</div>
            </div>
            <div class="summary-card">
                <div class="summary-title">Total Expenses</div>
                <div class="summary-value expense">$3,945.55</div>
            </div>
            <div class="summary-card">
                <div class="summary-title">Net Balance</div>
                <div class="summary-value income">$5,504.45</div>
            </div>
            <div class="summary-card">
                <div class="summary-title">Transactions</div>
                <div class="summary-value">47</div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-container">
            <h5 class="mb-3">Filter Transactions</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Date Range</label>
                        <select class="form-select" id="dateRange">
                            <option value="all">All Time</option>
                            <option value="today">Today</option>
                            <option value="week">This Week</option>
                            <option value="month" selected>This Month</option>
                            <option value="quarter">This Quarter</option>
                            <option value="year">This Year</option>
                            <option value="custom">Custom Range</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Type</label>
                        <select class="form-select" id="transactionType">
                            <option value="all">All Types</option>
                            <option value="income">Income Only</option>
                            <option value="expense">Expenses Only</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Category</label>
                        <select class="form-select" id="category">
                            <option value="all">All Categories</option>
                            <option value="salary">Salary Income</option>
                            <option value="house">House</option>
                            <option value="transportation">Transportation</option>
                            <option value="groceries">Groceries</option>
                            <option value="shopping">Shopping</option>
                            <option value="entertainment">Entertainment</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="filter-group">
                        <label class="filter-label">Search</label>
                        <input type="text" class="form-control" id="searchTerm" placeholder="Search transactions...">
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-filter" onclick="applyFilters()">
                    <i class="fas fa-filter me-2"></i>Apply Filters
                </button>
                <button class="btn btn-clear" onclick="clearFilters()">
                    <i class="fas fa-times me-2"></i>Clear All
                </button>
            </div>
        </div>

        <!-- Transactions List -->
        <div class="transactions-container">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Recent Transactions</h5>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-download me-1"></i>Export
                    </button>
                    <select class="form-select form-select-sm" style="width: auto;">
                        <option>Sort by Date</option>
                        <option>Sort by Amount</option>
                        <option>Sort by Category</option>
                    </select>
                </div>
            </div>
            
            <div id="transactionsList">
                <!-- Income Transactions -->
                <div class="transaction-item">
                    <div class="transaction-icon" style="background-color: #d4edda; color: #155724;">
                        OR
                    </div>
                    <div class="transaction-details">
                        <div class="transaction-name">Orlando Rodriguez</div>
                        <div class="transaction-meta">
                            <span><i class="fas fa-tag me-1"></i>Salary Income</span>
                            <span><i class="fas fa-credit-card me-1"></i>Bank account</span>
                            <span><i class="fas fa-calendar me-1"></i>2024/04/01</span>
                        </div>
                    </div>
                    <div class="transaction-amount positive">+$750.00</div>
                    <div class="transaction-actions">
                        <button class="btn-action" title="Edit">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-action" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                        <button class="btn-action" title="More">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                    </div>
                </div>

                <div class="transaction-item">
                    <div class="transaction-icon" style="background-color: #fff3cd; color: #856404;">
                        CA
                    </div>
                    <div class="transaction-details">
                        <div class="transaction-name">Carl Andrew</div>
                        <div class="transaction-meta">
                            <span><i class="fas fa-tag me-1"></i>Freelance Work</span>
                            <span><i class="fas fa-credit-card me-1"></i>Bank account</span>
                            <span><i class="fas fa-calendar me-1"></i>2024/03/27</span>
                        </div>
                    </div>
                    <div class="transaction-amount positive">+$300.00</div>
                    <div class="transaction-actions">
                        <button class="btn-action" title="Edit">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-action" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                        <button class="btn-action" title="More">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                    </div>
                </div>

                <!-- Expense Transactions -->
                <div class="transaction-item">
                    <div class="transaction-icon" style="background-color: #343a40; color: white;">
                        A
                    </div>
                    <div class="transaction-details">
                        <div class="transaction-name">Amazon</div>
                        <div class="transaction-meta">
                            <span><i class="fas fa-tag me-1"></i>Shopping</span>
                            <span><i class="fas fa-credit-card me-1"></i>Credit card</span>
                            <span><i class="fas fa-calendar me-1"></i>2024/03/24</span>
                        </div>
                    </div>
                    <div class="transaction-amount negative">-$147.00</div>
                    <div class="transaction-actions">
                        <button class="btn-action" title="Edit">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-action" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                        <button class="btn-action" title="More">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                    </div>
                </div>

                <div class="transaction-item">
                    <div class="transaction-icon" style="background-color: #e2e3e5; color: #383d41;">
                        CM
                    </div>
                    <div class="transaction-details">
                        <div class="transaction-name">Carrefour Market</div>
                        <div class="transaction-meta">
                            <span><i class="fas fa-tag me-1"></i>Groceries</span>
                            <span><i class="fas fa-credit-card me-1"></i>Credit card</span>
                            <span><i class="fas fa-calendar me-1"></i>2024/03/26</span>
                        </div>
                    </div>
                    <div class="transaction-amount negative">-$64.33</div>
                    <div class="transaction-actions">
                        <button class="btn-action" title="Edit">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-action" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                        <button class="btn-action" title="More">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                    </div>
                </div>

                <div class="transaction-item">
                    <div class="transaction-icon" style="background-color: #d1ecf1; color: #0c5460;">
                        N
                    </div>
                    <div class="transaction-details">
                        <div class="transaction-name">Netflix</div>
                        <div class="transaction-meta">
                            <span><i class="fas fa-tag me-1"></i>Entertainment</span>
                            <span><i class="fas fa-credit-card me-1"></i>Credit card</span>
                            <span><i class="fas fa-calendar me-1"></i>2024/03/29</span>
                        </div>
                    </div>
                    <div class="transaction-amount negative">-$9.90</div>
                    <div class="transaction-actions">
                        <button class="btn-action" title="Edit">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-action" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                        <button class="btn-action" title="More">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                    </div>
                </div>

                <div class="transaction-item">
                    <div class="transaction-icon" style="background-color: #d4edda; color: #155724;">
                        S
                    </div>
                    <div class="transaction-details">
                        <div class="transaction-name">Spotify</div>
                        <div class="transaction-meta">
                            <span><i class="fas fa-tag me-1"></i>Entertainment</span>
                            <span><i class="fas fa-credit-card me-1"></i>Credit card</span>
                            <span><i class="fas fa-calendar me-1"></i>2024/03/29</span>
                        </div>
                    </div>
                    <div class="transaction-amount negative">-$19.90</div>
                    <div class="transaction-actions">
                        <button class="btn-action" title="Edit">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-action" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                        <button class="btn-action" title="More">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <div class="pagination-container">
                <div class="results-info">
                    Showing 1-6 of 47 transactions
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled">
                            <a class="page-link" href="#" tabindex="-1">Previous</a>
                        </li>
                        <li class="page-item active">
                            <a class="page-link" href="#">1</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">2</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">3</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
